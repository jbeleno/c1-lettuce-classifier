@startuml 01_use_cases
' Figure 1 — Use Case Diagram (UML)
' Component: C1 Lettuce Growth-Stage Classifier
' Actors: Operator, Agronomist, System Admin

skinparam backgroundColor #0F172A
skinparam shadowing false
skinparam defaultFontName "Fira Sans"
skinparam defaultFontColor #F8FAFC

skinparam actor {
  BorderColor #94A3B8
  BackgroundColor #1E293B
  FontColor #F8FAFC
}
skinparam usecase {
  BorderColor #94A3B8
  BackgroundColor #1E293B
  FontColor #F8FAFC
  ArrowColor #38BDF8
}
skinparam ArrowColor #38BDF8
skinparam ArrowFontColor #94A3B8
skinparam ArrowFontName "Fira Code"
skinparam package {
  BorderColor rgba(148,163,184,0.30)
  BackgroundColor #0F172A
  FontColor #94A3B8
}
skinparam noteFontColor #94A3B8
skinparam noteBackgroundColor #1E293B
skinparam noteBorderColor rgba(148,163,184,0.30)

left to right direction

actor "Greenhouse\nOperator" as Op
actor "Agronomist" as Agro
actor "System Admin" as Admin

package "C1 — Lettuce Growth-Stage Classifier" {
  usecase "Capture / upload\npod image" as UC1
  usecase "Predict growth\nstage" as UC2
  usecase "Choose a specific\nmodel" as UC3
  usecase "Use the\nensemble" as UC4
  usecase "Review prediction\nhistory" as UC5
  usecase "Filter history by\nlabel or model" as UC6
  usecase "Compare model\nmetrics" as UC7
  usecase "List trained\nmodels" as UC8
  usecase "Maintain the\ntrained models" as UC9
}

Op --> UC1
Op --> UC2
Op --> UC5

Agro --> UC2
Agro --> UC3
Agro --> UC4
Agro --> UC5
Agro --> UC6
Agro --> UC7

Admin --> UC8
Admin --> UC9

UC2 .> UC1 : <<include>>
UC4 .> UC2 : <<extend>>
UC3 .> UC2 : <<extend>>
UC6 .> UC5 : <<extend>>
@enduml
