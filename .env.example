# ── Data ─────────────────────────────────────────────────────────────────────
# Path to the raw Roboflow dataset (multilabel-classification folder export).
# On the lab workstation, after running `make fetch-data` this defaults to
# ./data/lettuce_pallets — set it explicitly if you put it elsewhere.
RAW_DATASET_PATH=./data/lettuce pallets.v2i.multiclass

# Reproducibility — keep this fixed across collaborators.
SPLIT_SEED=42

# ── Training knobs ───────────────────────────────────────────────────────────
# Defaults below assume the lab workstation (RTX 2090, 24 GB RAM, Ubuntu).
# On a laptop, drop BATCH_SIZE to 16-32 and NUM_WORKERS to 2-4.
BATCH_SIZE=64
NUM_WORKERS=8

# TensorFlow CNN trainers run a two-phase fit. Bump these when training on
# the workstation, drop them on a laptop.
TF_HEAD_EPOCHS=20
TF_FINE_TUNE_EPOCHS=8

# PyTorch transformer trainers (ViT, Swin).
TORCH_EPOCHS=12

# auto = enable fp16 when a CUDA GPU is detected.
# 0    = force float32 everywhere (use on CPU / Apple Metal where fp16 gives
#        no real speedup or fights with the driver).
MIXED_PRECISION=auto

# ── Backend ──────────────────────────────────────────────────────────────────
# FastAPI persists prediction history here.
POSTGRES_DSN=postgresql+psycopg://postgres:postgres@localhost:5432/lettuce
